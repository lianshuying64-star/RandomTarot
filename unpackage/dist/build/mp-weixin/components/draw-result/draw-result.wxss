.draw-result{width:100%}.spread-info{background:linear-gradient(135deg,#f8f4f0,#e8dfd6);padding:25rpx;border-radius:15rpx;margin-bottom:30rpx;border-left:6rpx solid #8B4513;text-align:center}.spread-name{display:block;font-size:32rpx;font-weight:700;color:#8b4513;margin-bottom:10rpx}.spread-desc{display:block;font-size:26rpx;color:#666}.cards-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(350rpx,1fr));gap:30rpx;justify-items:center}.card-item{display:flex;flex-direction:column;align-items:center;gap:15rpx}.position-label{background:rgba(139,69,19,.1);padding:15rpx 20rpx;border-radius:10rpx;text-align:center;border:1rpx solid #DAA520;min-width:200rpx}.position-title{display:block;font-size:26rpx;font-weight:700;color:#8b4513;margin-bottom:5rpx}.position-desc{display:block;font-size:22rpx;color:#654321}@media (max-width: 750rpx){.cards-grid{grid-template-columns:1fr}}
