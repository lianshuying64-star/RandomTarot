<view class="history-container"><view class="header"><text class="title">📜 抽牌历史</text><text class="subtitle">共 {{a}} 次记录</text></view><view wx:if="{{b}}" class="history-list"><view wx:for="{{c}}" wx:for-item="item" wx:key="g" class="history-item" bindtap="{{item.h}}"><view class="item-header"><text class="item-time">{{item.a}}</text><text class="item-seed">种子: {{item.b}}</text></view><view class="item-cards"><text class="cards-count">{{item.c}} 张牌</text><view class="card-previews"><text wx:for="{{item.d}}" wx:for-item="card" wx:key="b" class="card-preview">{{card.a}}</text></view></view><view class="item-params"><text class="param">算法: {{item.e}}</text><text class="param">方法: {{item.f}}</text></view></view></view><view wx:else class="empty-state"><text class="empty-icon">📭</text><text class="empty-text">暂无抽牌记录</text><text class="empty-subtext">返回首页开始抽牌吧</text></view><view class="action-buttons"><button bindtap="{{d}}" class="clear-btn">清空历史</button><button bindtap="{{e}}" class="back-btn">返回首页</button></view><uni-popup wx:if="{{o}}" class="r" u-s="{{['d']}}" u-r="detailPopup" u-i="6b41511b-0" bind:__l="__l" u-p="{{o}}"><view wx:if="{{f}}" class="detail-popup"><text class="popup-title">抽牌详情</text><view class="popup-time"><text>时间: {{g}}</text></view><view class="popup-seed"><text>种子: {{h}}</text></view><view class="popup-cards"><text class="cards-title">抽到的牌:</text><view wx:for="{{i}}" wx:for-item="card" wx:key="d" class="popup-card"><text class="card-name">{{card.a}} ({{card.b}})</text><text class="card-meaning">{{card.c}}</text></view></view><view class="popup-params"><text class="params-title">随机参数:</text><text>算法: {{j}}</text><text>抽牌数: {{k}}</text><text>方法: {{l}}</text></view><button bindtap="{{m}}" class="close-btn">关闭</button></view></uni-popup></view>