        "navigationBarBackgroundColor": "#8B4513",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/history/history",
      "style": {
        "navigationBarTitleText": "抽牌历史",
        "enablePullDownRefresh": false,
        "navigationBarBackgroundColor": "#8B4513",
        "navigationBarTextStyle": "white"
      }
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "white",
    "navigationBarTitleText": "塔罗牌抽牌器",
    "navigationBarBackgroundColor": "#8B4513",
    "backgroundColor": "#F8F8F8",
